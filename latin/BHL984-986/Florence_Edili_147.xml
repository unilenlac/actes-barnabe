<body>
	<div>
		<milestone n="titre-prologue" />
		<pb n="129v" /><cb n="1" />
				<head type="initial"><lb n="22" />
			In sancti Barnabe apostoli.
		</head>
			<milestone n="prologue" />
			<p>
				<seg type="lectio" place="inline" hand="manus1">Lectio ia</seg>
				<lb n="23" />
				Barnabas he<lb n="24" break="no"/>braice,
				latine<lb n="25" />
				interpretatur<lb n="26" />
				filius prophete<lb n="27" />
				uel filius con<lb n="28" break="no"/>solationis.
				Barnabas qui<lb n="29" />
				et Ioseph natione Cipriȩ ci<lb n="30" break="no"/>uitatis,
				que ex Cyro rege Per<lb n="31" break="no"/>sarum
				fundata est, cum Pau<lb n="32" break="no"/>lo
				ingentibus apostolatum ad<cb n="2" /><lb n="1" break="no"/>eptus
				est. Deinde propter Iohannem<lb n="2" />
				discipulum, qui etiam cogno<lb n="3" break="no"/>mento
				Marcus appellatur,<lb n="4" />
				seiunctus a Paulo  nichilo<lb n="5" break="no"/>minus
				euangelii praedicatione<lb n="6" />
				sibi opus iniunctum exercu<lb n="7" break="no"/>it,
				martirio coronatus.<lb n="8" />
				Cuius festiuitas celebratur<lb n="9" />
				tercio ydus iunii.
			</p>
	</div>

<body>
	<div>
		<milestone n="titre-prologue" />
		<pb n="41r" /><cb n="1" />
				<head type="initial">
			In sancti<lb n="13" />
			Barnabe apostoli.
		</head>
		<milestone n="prologue" />
		<div>
			<p>
				<seg place="inline" hand="manus1" type="lectio">Lectio</seg>
				<lb n="14" />
				Barnabas hebra<lb n="15" break="no"/>ice,
				latine inter<lb n="16" break="no"/>pretatur
				filius prophete,<lb n="17" />
				uel filius consolationis. Barna<lb n="18" break="no"/>bas
				qui Ioseph natione Cyprie<lb n="19" />
				ciuitatis, que ex  Cyro rege Per<lb n="20" break="no"/>sarum
				fundata extitit, cum Paulo<lb n="21" />
				ingentibus apostolatum adeptus<lb n="22" />
				est. Deinde propter Iohannem disci<lb n="23" break="no"/>pulum,
				qui etiam cognomento Mar<lb n="24" break="no"/>chus
				appellatur  seiunctus a Pau<lb n="25" break="no"/>lo,
				nichilominus euangelii pre<lb n="26" break="no"/>dicatione
				sibi opus iniunctum<lb n="27" />
				exercuit,  martyrio coronatus. Cuius<lb n="28" />
				festiuitas celebratur tertio idus<lb n="29" />
				iunii.
			</p>
		</div>
	</div>

<body>
	<div>
		<milestone n="titre-prologue" />
		<pb n="104v" /><cb n="2" />
				<head type="initial"><lb n="1" />
			In festo sancti Barnabe<lb n="2" />
			apostoli.
		</head>
		<milestone n="prologue" />
		<p>
			Barnabas<lb n="3" />
			ebraice, lati<lb n="4" break="no"/>ne
			interpreta<lb n="5" break="no"/>tur
			filius pro<lb n="6" break="no"/>phete,
			uel filius conso<lb n="7" break="no"/>lationis.
			Barnabas qui<lb n="8" />
			et Ioseph natione Cy<lb n="9" break="no"/>prie
			ciuitatis, <add place="above" hand="corr1">que</add> ex Cyro<lb n="10" />
			rege Persarum fundata,<lb n="11" />
			cum Paulo ingentibus<lb n="12" />
			apostolatum adeptus est.<lb n="13" />
			Deinde propter Iohannem di<lb n="14" break="no"/>scipulum,
			qui etiam cogno<lb n="15" break="no"/>mento
			Marcus appel<lb n="16" break="no"/>latur
			seiunctus a Pau<lb n="17" break="no"/>lo,
			nichilominus euangeli<lb n="18" break="no"/>ce
			praedicationis sibi o<lb n="19" break="no"/>pus
			iniunctum exercuit,<lb n="20" />
			martirio coronatus. Cu<lb n="21" break="no"/>ius
			festiuitas, celebra<lb n="22" break="no"/>tur
			tercio ydus iunii.
		</p>

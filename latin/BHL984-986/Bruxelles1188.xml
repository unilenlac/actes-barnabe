<body>
	<div>
		<milestone n="prologue" />
		<pb n="120v" />
		<cb n="1" />
				<p><lb n="8" />
			<space quantity="1" />arnabas hebraice, latine inter<lb n="9" break="no"/>pretatur
			filius prophete uel filius con<lb n="10" break="no"/>solationis.
			Barnabas qui et Ioseph natione<lb n="11" />
			Cyprie ciuitatis et a  Ciro rege Persa<lb n="12" break="no"/>rum
			fundata extitit,  cum Paulo ingen<lb n="13" break="no"/>tibus
			apostolatum adeptus est
			Deinde prop<lb n="14" break="no"/>ter
			Iohannem <del rend="strike" unit="character">apostolum</del>
			discipulum qui <sic>eciam</sic> cog<lb n="15" break="no"/>nomento
			Marcus appellatur, se<lb n="16" break="no"/>iunctus
			a Paulo,  nichilominus euange<lb n="17" break="no"/>lii
				praedicatione sibi opus <subst>
					<del rend="other">inuentum</del>
					<add place="margin-left" hand="corr1">iniunctum</add>
				</subst>
			exer<lb n="18" break="no"/>cuit
			martirio coronatus. Cuius fes<lb n="19" break="no"/>tiuitas
			celebratur, tercio idus iunii
		</p>
